{
  "name": "splash-protocol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/src/main.js",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test dist/test/*.js",
    "coverage": "npm run build && c8 --reporter=text --reporter=lcov --all --include=dist/src/**/*.js node --test dist/test/*.js"
  },
  "dependencies": {
    "nats": "^2.29.3"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "c8": "^10.1.3",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3"
  }
}
