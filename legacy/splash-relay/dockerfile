FROM node:20-alpine

# Once the issue with serialnode cpp bindings on Alpine goes away, remove these
RUN apk add --update --no-cache make g++ linux-headers python3 py3-pip

#ENV SERVER_ADDRESS=${SERVER_ADDRESS}
#ENV SERIAL_DEVICE_PATH=${SERIAL_DEVICE_PATH}

# This enables serialports verbose debug mode
#ENV DEBUG=serialport*

RUN addgroup node dialout

USER node

WORKDIR /home/node/splash/splash-relay

COPY --chown=node:node splash-relay/ .

RUN npm ci && npm cache clean --force

# Work-around for outdated cpp bindings is to rebuild them on the device
WORKDIR /home/node/splash/splash-relay/node_modules/@serialport/bindings-cpp
RUN npm run rebuild
WORKDIR /home/node/splash/splash-relay

RUN chmod +x ./run.sh

EXPOSE 8080

ENTRYPOINT ["node", "./dist/main.js" ]